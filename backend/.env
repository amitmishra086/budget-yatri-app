# Database - For local dev, SQLite is used automatically if this is left as-is.
# For production (Render/Railway/Supabase), set this to your PostgreSQL URL:
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./travel_budget.db

# JWT Secret - CHANGE THIS in production! Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-this-in-production-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# AI Integration (optional - leave blank to use mock/template suggestions)
# Get key from https://console.anthropic.com
ANTHROPIC_API_KEY=
